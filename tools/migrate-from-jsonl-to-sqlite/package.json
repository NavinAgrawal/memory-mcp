{
  "name": "migrate-from-jsonl-to-sqlite",
  "version": "1.0.0",
  "description": "Migration tool for Memory MCP - converts between JSONL and SQLite storage formats",
  "type": "module",
  "scripts": {
    "build": "bun build migrate-from-jsonl-to-sqlite.ts --compile --outfile migrate-from-jsonl-to-sqlite.exe",
    "build:ts": "tsc",
    "start": "bun run migrate-from-jsonl-to-sqlite.ts"
  },
  "bin": {
    "migrate-from-jsonl-to-sqlite": "./dist/migrate-from-jsonl-to-sqlite.js"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
