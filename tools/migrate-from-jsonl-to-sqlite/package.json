{
  "name": "migrate-from-jsonl-to-sqlite",
  "version": "1.0.0",
  "description": "Migration tool for Memory MCP - converts between JSONL and SQLite storage formats",
  "scripts": {
    "build": "npm run build:ts && npm run build:exe",
    "build:ts": "tsc",
    "build:exe": "pkg dist/migrate-from-jsonl-to-sqlite.js --target node18-win-x64 --output migrate-from-jsonl-to-sqlite.exe",
    "start": "node dist/migrate-from-jsonl-to-sqlite.js"
  },
  "bin": {
    "migrate-from-jsonl-to-sqlite": "./dist/migrate-from-jsonl-to-sqlite.js"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "pkg": "^5.8.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
