{
  "name": "create-dependency-graph",
  "version": "1.0.0",
  "description": "Generate dependency graph documentation for TypeScript projects",
  "type": "module",
  "scripts": {
    "build": "npm run build:ts && npm run build:exe",
    "build:ts": "tsc",
    "build:exe": "pkg dist/create-dependency-graph.js --target node18-win-x64 --output create-dependency-graph.exe",
    "start": "node dist/create-dependency-graph.js"
  },
  "bin": {
    "create-dependency-graph": "./dist/create-dependency-graph.js"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.2",
    "pkg": "^5.8.1",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
