{
  "name": "compress-for-context",
  "version": "1.0.0",
  "description": "Compress files for LLM context windows",
  "type": "module",
  "scripts": {
    "build": "npm run build:ts && npm run build:exe",
    "build:ts": "tsc",
    "build:exe": "pkg dist/compress-for-context.js --target node18-win-x64 --output compress-for-context.exe",
    "start": "node dist/compress-for-context.js"
  },
  "bin": {
    "compress-for-context": "./dist/compress-for-context.js"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "pkg": "^5.8.1",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
